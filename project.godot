; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

resources_spreadsheet_view/array_color_tint=100.0
resources_spreadsheet_view/color_rows=true
resources_spreadsheet_view/array_min_width=128.0
resources_spreadsheet_view/resource_preview_size=32.0
resources_spreadsheet_view/clip_headers=false
resources_spreadsheet_view/dupe_arrays=true
resources_spreadsheet_view/context_menu_on_leftclick=false
resources_spreadsheet_view/fold_docks=true
resources_spreadsheet_view/resource_cell_label_mode=1
resources_spreadsheet_view/freeze_first_column=true

[application]

config/name="Component Library"
run/main_scene="uid://1ta4uyq1kbo4"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://bmavvkyg5xb7a"

[audio]

buses/default_bus_layout="res://assets/assets_system/system_audio_bus.tres"

[autoload]

Directory="*res://autoloads/directory/directory.gd"
Settings="*res://autoloads/settings/settings.gd"
SessionManager="*uid://mrlxt1xnae7"
EventBus="*res://autoloads/event_bus/event_bus.gd"
AudioPlayer="*uid://drsnhnk2a2dgq"
LoadingScreen="*res://autoloads/loading_screen/loading_screen.tscn"
PopupManager="*uid://c2q6d750fjtp3"
TimescaleManager="*uid://6snncq3vy4gt"
PostProcessing="*res://autoloads/post_processing/post_processing.tscn"
ObjectPool="*uid://kpaelys6e6lb"
SystemManager="*uid://ct1prsgq5ie3o"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"
mouse_cursor/custom_image="uid://deaichbddumov"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-sqlite/plugin.cfg", "res://addons/inspector_tabs/plugin.cfg", "res://addons/resources_spreadsheet_view/plugin.cfg", "res://addons/theme_generator/theme_plugin/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "yellow",
"res://autoloads/": "gray",
"res://data/": "red",
"res://entities/": "teal",
"res://environment/": "green",
"res://levels/": "orange",
"res://managers/": "blue",
"res://scripts/": "pink",
"res://user_interface/": "purple"
}

[gui]

fonts/dynamic_fonts/use_oversampling=false

